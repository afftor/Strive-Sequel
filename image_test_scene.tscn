[sub_resource type="Shader" id=4]
code = "shader_type canvas_item;

uniform float outline_width = 2.0;
uniform vec4 outline_color : hint_color;
uniform float opacity = 1.0;
uniform float speed = 0.1;

const vec2 dir1 = vec2(0.3, 1.0);
const vec2 dir2 = vec2(-0.3, 1.0);
const vec2 dir3 = vec2(-0.1, -0.8);

const float PI = 3.14;

uniform sampler2D tex;

vec2 force_loop(vec2 arg){
	vec2 res = arg * 2.0;
	if (res.x > 1.0) 
		res.x = 2.0 - res.x;
	if (res.y > 1.0) 
		res.y = 2.0 - res.y;
	return res;
}


void fragment() {
	vec4 col = texture(TEXTURE, UV);
	vec2 ps = TEXTURE_PIXEL_SIZE;
	vec4 shadow = vec4(0.0);
	for (float k = 0.1; k <= 1.0; k += 0.1) {
		shadow += texture(TEXTURE, UV + vec2(-outline_width, 0.0) * ps * k);
		shadow += texture(TEXTURE, UV + vec2(0.0, -outline_width) * ps * k);
		shadow += texture(TEXTURE, UV + vec2(0.0, outline_width) * ps * k);
		shadow += texture(TEXTURE, UV + vec2(outline_width, 0.0) * ps * k);
	}
	shadow /= 40.0;
	
	vec2 pos1 = UV + TIME * speed * dir1;
	pos1 = force_loop(pos1 - floor(pos1));
	vec4 col1 = texture(tex, pos1);
	vec2 pos2 = UV + TIME * speed * dir2;
	pos2 = force_loop(pos2 - floor(pos2));
	vec4 col2 = texture(tex, pos2);
	vec2 pos3 = UV + TIME * speed * dir3;
	pos3 = force_loop(pos3 - floor(pos3));
	vec4 col3 = texture(tex, pos3);
	
	shadow = vec4(sqrt(col1.r) * outline_color.r, sqrt(col2.g) * outline_color.g, sqrt(col3.b) * outline_color.b, sqrt(shadow.a) * opacity);
	//col.a = min(col.a, sqrt(sqrt(1.0 - opacity)));
	COLOR = mix(shadow, col, col.a);
	//COLOR = mix(col, outline_color, (maxa - mina)*opacity);
}"

