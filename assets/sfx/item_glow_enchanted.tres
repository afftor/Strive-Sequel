[gd_resource type="ShaderMaterial" load_steps=10 format=2]

[sub_resource type="Shader" id=17]
code = "shader_type canvas_item;

uniform vec4 outline_color : hint_color;
uniform float opacity = 1.0;
uniform float speed = 0.1;
uniform float speed_2 = 0.1;
uniform float speed_3 = 0.1;

const vec2 dir1 = vec2(0.3, 1.0);
const vec2 dir2 = vec2(-0.3, 1.0);
const vec2 dir3 = vec2(-0.1, -0.8);

const float PI = 3.14;
const float EPS = 1.0/512.0;

uniform sampler2D tex_main;
uniform sampler2D tex_main_2;
uniform sampler2D tex_mask_1;
uniform sampler2D tex_mask_2;


float border(float val) {
	float res = sqrt(val) / 3.5 - 0.17;
	res = res * 12.0;
	return clamp(res, 0.0, 1.0);
}


void fragment() {
	vec4 col = texture(TEXTURE, UV);
	vec2 ps = TEXTURE_PIXEL_SIZE;
	vec4 shadow = vec4(1.0);
	float time_mod = TIME * speed;
	float time_mod_2 = TIME * speed_2;
	float time_mod_3 = TIME * speed_3;
	
	vec2 pos1 = UV + time_mod * dir1;
	vec4 col1 = 1.0 - sqrt(abs(texture(tex_main, pos1) - texture(tex_main_2, pos1)));
	vec2 pos2 = UV + time_mod * dir1;
	vec4 col2 = 1.0 - sqrt(abs(texture(tex_main, pos2) - texture(tex_main_2, pos2)));
	vec2 pos3 = UV + time_mod * dir1;
	vec4 col3 = 1.0 - sqrt(abs(texture(tex_main, pos3) - texture(tex_main_2, pos3)));
	
	vec2 pos1_1 = (UV - vec2(0.5)) * 0.7 * mat2(vec2(cos(time_mod_2), sin(time_mod_2)), vec2(-sin(time_mod_2), cos(time_mod_2))) + vec2(0.5);
	vec2 pos1_2 = (UV - vec2(0.5)) * 0.7 * mat2(vec2(cos(time_mod_2), -sin(time_mod_2)), vec2(sin(time_mod_2), cos(time_mod_2))) + vec2(0.5);
	shadow.a = texture(tex_mask_1, pos1_1).x * (abs(sin(time_mod_3))) + texture(tex_mask_2, pos1_2).x * (abs(cos(time_mod_3)));
	
	shadow = vec4(col1.r * outline_color.r, col2.g * outline_color.g, col3.b * outline_color.b, border(shadow.a) * opacity);
	COLOR = mix(shadow, col, col.a);
}"

