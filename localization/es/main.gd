	FIGHTERSINTRODUCTION2_3_1 = "Y, por supuesto, ofrecemos a nuestros mejores luchadores para contratar. Como eres un nuevo terrateniente, te ofrecemos un recluta gratis si te unes a nosotros primero.",
	FIGHTERSINTRODUCTION2_4 = "— Has vuelto. ¿Qué has decidido?",
	FIGHTERSINTRODUCTION2_5 = "— Has vuelto. ¿Ha pasado algo?",
