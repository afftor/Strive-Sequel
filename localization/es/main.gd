	LOOKING_FOR_PRINCESS_44 = """{color=aqua|Sacerdotisa: — Entonces procederemos según lo decidido.}

""",
	LOOKING_FOR_PRINCESS_45 = """Con tu aprobación, Zephyra avanza. La sacerdotisa la observa pensativamente.

