	BOLTHAR_HARA_OPT_TREATMENT = "¿Cómo te han estado tratando los rebeldes?",
	BOLTHAR_HARA_OPT_TOKING = "Necesito llevarte de regreso al Rey.",
	BOLTHAR_HARA_REPLY_REBELS = """Hara se ajusta las gafas y se encoge de hombros con indiferencia; una sonrisa burlona se dibuja en sus labios.

