	LOOKING_FOR_PRINCESS_39 = """{color=aqua|Sacerdotisa: — No nos importan las amenazas mezquinas. Se aplicará el castigo tradicional como siempre.}

""",
	LOOKING_FOR_PRINCESS_40 = "Observas que Zephyra te hace señales cautelosas para que la dejes negociar en tu nombre.",
