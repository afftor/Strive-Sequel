	HOLLOW_PASS_OPT_THING = "Solo quiero una cosa determinada de él y eso es todo.",
	HOLLOW_PASS_TEMPLE = """Bolthar escucha tu declaración con calma, sin mostrar ninguna emoción. Después de un breve momento de silencio, continúa como si hubiera olvidado su pregunta anterior.

