	AMELIA_TRIAL_16_OPTION_1 = "*Tenter d'analyser le dossier à la recherche d'incohérences*",
	AMELIA_TRIAL_16_OPTION_2 = """Peut-être devrions-nous interroger les esclaves qui étaient avec Amelia lorsqu'elle a été kidnappée ?""",
