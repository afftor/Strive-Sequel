	REIMENCOUNTER2REPLY2 = "[Charme] Tu ne devrais pas risquer ta vie pour une pute, elle ne fait que t'utiliser",
	REIMENCOUNTER2REPLY3 = "Je ne vais pas payer tes caprices de ma poche",
