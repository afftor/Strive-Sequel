	REIMENCOUNTER3_1REPLY1 = "Bien. J'y vais alors.",
	REIMENCOUNTER3_2 = "- Non, tu ne comprends pas ! Ce n'est pas une simple pute. Ecoutez, il faut que vous m'aidiez à sortir de là...",
	REIMENCOUNTER3_2REPLY1 = "Je ne vais pas payer tes caprices de ma poche",
	REIMENCOUNTER3_2REPLY2 = "Je vais y réfléchir",
	REIMENCOUNTER4_1 = "- Je comprends... Fais ce que tu dois faire. A la fin, notre amour l'emportera sur tout le reste.",
	REIMENCOUNTER4_2 = "- Merci ! Je... devrais probablement me dépêcher maintenant. J'essaierai de vous rendre cette faveur un jour.",
